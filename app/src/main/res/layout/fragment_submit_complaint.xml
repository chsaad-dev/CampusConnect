<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:title="Submit Complaint"
            app:titleTextAppearance="@style/CampusConnect.TextAppearance.Toolbar"
            app:navigationIcon="@drawable/ic_arrow_back"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Category Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:boxCornerRadiusTopStart="@dimen/corner_medium"
            app:boxCornerRadiusTopEnd="@dimen/corner_medium"
            app:boxCornerRadiusBottomStart="@dimen/corner_medium"
            app:boxCornerRadiusBottomEnd="@dimen/corner_medium"
            app:boxStrokeColor="@color/text_input_stroke_color"
            android:hint="Category">
            <AutoCompleteTextView
                android:id="@+id/actv_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textSize="@dimen/text_body" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Priority Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:boxCornerRadiusTopStart="@dimen/corner_medium"
            app:boxCornerRadiusTopEnd="@dimen/corner_medium"
            app:boxCornerRadiusBottomStart="@dimen/corner_medium"
            app:boxCornerRadiusBottomEnd="@dimen/corner_medium"
            app:boxStrokeColor="@color/text_input_stroke_color"
            android:hint="Priority">
            <AutoCompleteTextView
                android:id="@+id/actv_priority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textSize="@dimen/text_body" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Location -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/CampusConnect.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:hint="Location (e.g. Room 302, Library)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textSize="@dimen/text_body" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/CampusConnect.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:hint="Describe the issue...">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="4"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textSize="@dimen/text_body" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Image attachment -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_attach_image"
            style="@style/CampusConnect.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Attach Supporting Image"
            android:layout_marginBottom="@dimen/spacing_md"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconTint="?attr/colorPrimary" />

        <!-- Preview Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_image_preview"
            style="@style/CampusConnect.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/spacing_lg">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">
                <ImageView
                    android:id="@+id/iv_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Attached Image" />
                <ImageButton
                    android:id="@+id/btn_remove_image"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="end|top"
                    android:layout_margin="@dimen/spacing_sm"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/white" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            style="@style/CampusConnect.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Submit Complaint"
            android:textSize="@dimen/text_subtitle"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_md"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
