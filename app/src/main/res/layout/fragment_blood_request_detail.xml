<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceVariant"
    android:padding="@dimen/spacing_lg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:title="Blood Request Details"
        app:titleTextAppearance="@style/CampusConnect.TextAppearance.Toolbar"
        app:navigationIcon="@drawable/ic_arrow_back"
        android:layout_marginBottom="@dimen/spacing_md" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/content_card"
        style="@style/CampusConnect.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">
                
                <TextView
                    android:id="@+id/tv_blood_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/blood_red"
                    android:layout_marginEnd="@dimen/spacing_md"
                    tools:text="O+" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Urgency:"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_urgency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_subtitle"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#FFA800"
                        tools:text="High" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/divider"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Attached Image Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_post_image"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="@dimen/spacing_md"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/iv_post_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Attached Image" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hospital / Location:"
                android:textSize="@dimen/text_caption"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_hospital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="@dimen/spacing_lg"
                tools:text="City General Hospital" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accept_request"
                style="@style/CampusConnect.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Accept Request (Contact)"
                app:icon="@android:drawable/ic_menu_call"
                app:iconTint="@color/white" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
