<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">
            <ImageView
                android:id="@+id/iv_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="Event Banner" />
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:navigationIconTint="@color/white"
                android:background="@android:color/transparent" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_headline"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginBottom="6dp"
                    tools:text="Symposium 2026" />

                <TextView
                    android:id="@+id/tv_host"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_body"
                    android:textColor="?attr/colorPrimary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_md"
                    tools:text="Society" />

                <!-- Countdown Timer Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_countdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/corner_medium"
                    app:cardElevation="@dimen/card_elevation_flat"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    android:layout_marginBottom="@dimen/spacing_lg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EVENT STARTS IN"
                            android:textSize="@dimen/text_overline"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnPrimaryContainer" />
                        <TextView
                            android:id="@+id/tv_countdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_headline"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:layout_marginTop="4dp"
                            tools:text="02d : 10h : 30m : 15s" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About Event"
                    android:textSize="@dimen/text_subtitle"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginBottom="6dp" />
                
                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    tools:text="Detailed description of symposium..." />

                <!-- Action Register Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_register"
                    style="@style/CampusConnect.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Register For Event"
                    android:textSize="@dimen/text_subtitle"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_lg" />

                <!-- Ticket Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_ticket"
                    style="@style/CampusConnect.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    tools:visibility="visible">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="YOUR ENTRY PASS"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="@dimen/text_subtitle"
                            android:textColor="?attr/colorPrimary"
                            android:layout_marginBottom="12dp" />
                        <ImageView
                            android:id="@+id/iv_qr"
                            android:layout_width="150dp"
                            android:layout_height="150dp"
                            android:src="@android:drawable/ic_menu_crop"
                            android:contentDescription="Pass QR Code"
                            android:layout_marginBottom="12dp" />
                        <TextView
                            android:id="@+id/tv_ticket_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_secondary"
                            tools:text="Ticket ID: TICKET_symp123" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
