<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_md"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="@dimen/corner_medium"
    app:cardElevation="@dimen/card_elevation_flat"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="@dimen/card_stroke_width"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <!-- Header: Author Details & Post Type -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_sm">

            <com.campusconnect.core.widgets.UserAvatarView
                android:id="@+id/view_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:avatarSize="40dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_author_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="Saad Fareedi" />

                <TextView
                    android:id="@+id/tv_username_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    tools:text="\@saad_fareedi • 2h ago" />
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_post_type"
                style="@style/CampusConnect.Chip.PostType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="NOTE" />
        </LinearLayout>

        <!-- Caption / Text content -->
        <TextView
            android:id="@+id/tv_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textColor="?attr/colorOnSurface"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="@dimen/spacing_sm"
            tools:text="Here are the notes for Android Development. Hope it helps!" />

        <!-- Media Attachment Container -->
        <FrameLayout
            android:id="@+id/media_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Image View with rounded corners -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_post_image"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="?attr/colorSurfaceVariant"
                android:contentDescription="@null"
                android:visibility="gone"
                app:shapeAppearance="@style/CampusConnect.ShapeSmall"
                tools:visibility="visible" />

            <!-- Document Card (PDF/DOCX/PPT) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_document"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/corner_small"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="@dimen/card_stroke_width"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                tools:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iv_doc_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_save"
                        app:tint="?attr/colorPrimary"
                        android:contentDescription="@null" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_sm">

                        <TextView
                            android:id="@+id/tv_doc_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="lecture_notes.pdf" />

                        <TextView
                            android:id="@+id/tv_doc_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="@dimen/spacing_xxs"
                            tools:text="PDF Document" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Video Player stub -->
            <FrameLayout
                android:id="@+id/video_placeholder"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="?attr/colorSurfaceVariant"
                android:visibility="gone"
                tools:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@null" />
            </FrameLayout>

        </FrameLayout>

        <!-- Divider above actions -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_height"
            android:background="@color/divider"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- Actions Panel: Like, Comment, Share -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Like Button -->
            <LinearLayout
                android:id="@+id/btn_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_sm"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/iv_like"
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_like_outline"
                    app:tint="@color/text_secondary"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_secondary"
                    tools:text="12" />
            </LinearLayout>

            <!-- Comment Button -->
            <LinearLayout
                android:id="@+id/btn_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="@dimen/spacing_lg"
                android:paddingVertical="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_sm"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_comment"
                    app:tint="@color/text_secondary"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_comment_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_secondary"
                    tools:text="4" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <!-- Share Button -->
            <ImageView
                android:id="@+id/btn_share"
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_share"
                app:tint="@color/text_secondary"
                android:contentDescription="@null"
                android:padding="2dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
