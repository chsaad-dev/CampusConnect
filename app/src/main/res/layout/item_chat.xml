<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_md"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar with online indicator -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_avatar"
            android:layout_width="@dimen/avatar_medium"
            android:layout_height="@dimen/avatar_medium"
            android:src="@drawable/ic_person"
            android:contentDescription="User Avatar" />

        <!-- Online indicator dot -->
        <View
            android:id="@+id/view_online_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_online_indicator"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Name and last message -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_sm">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_subtitle"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSurface"
            tools:text="Alice Smith" />

        <TextView
            android:id="@+id/tv_last_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="@dimen/spacing_xxs"
            tools:text="Hey, are you still offering the ride?" />
    </LinearLayout>

    <!-- Time and unread badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end|center_vertical"
        android:layout_marginStart="@dimen/spacing_sm">

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_secondary"
            tools:text="10:30 AM" />

        <!-- Unread count badge -->
        <TextView
            android:id="@+id/tv_unread_count"
            android:layout_width="@dimen/badge_size"
            android:layout_height="@dimen/badge_size"
            android:gravity="center"
            android:textSize="@dimen/badge_text_size"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_unread_badge"
            android:visibility="gone"
            android:layout_marginTop="@dimen/spacing_xs"
            tools:text="3"
            tools:visibility="visible" />

    </LinearLayout>

</LinearLayout>
