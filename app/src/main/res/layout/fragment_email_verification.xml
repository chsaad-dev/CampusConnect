<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg"
    android:gravity="center"
    android:background="?attr/android:colorBackground">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@android:drawable/ic_dialog_email"
        app:tint="?attr/colorPrimary"
        android:contentDescription="@string/email_verification"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/verify_your_email"
        android:textSize="@dimen/text_headline"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:textColor="?attr/colorOnBackground" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/verification_instructions"
        android:textSize="@dimen/text_body"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:paddingHorizontal="@dimen/spacing_md" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_check_verification"
        style="@style/CampusConnect.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/ive_verified"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_resend_email"
        style="@style/CampusConnect.Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="@string/resend_email"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold"
        android:textSize="@dimen/text_body" />

</LinearLayout>
