<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:title="Note Details"
        app:titleTextAppearance="@style/CampusConnect.TextAppearance.Toolbar"
        app:titleTextColor="?attr/colorOnSurface"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="@color/divider" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/content_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Top Banner Visual -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="?attr/colorPrimary">

                <ImageView
                    android:id="@+id/iv_note_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Note Cover Preview" />

                <ImageView
                    android:id="@+id/iv_default_icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/white"
                    android:contentDescription="Doc Icon" />
            </FrameLayout>

            <!-- Metadata details card wrapper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg"
                android:background="?attr/colorSurface"
                android:layout_marginTop="-16dp"
                android:elevation="4dp">

                <!-- Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STUDY NOTES"
                    android:textSize="@dimen/text_overline"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/chip_note_text"
                    android:background="@color/chip_note_bg"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Subject Title -->
                <TextView
                    android:id="@+id/tv_subject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_headline"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="6dp"
                    tools:text="Advanced Mathematics" />

                <!-- Teacher Name -->
                <TextView
                    android:id="@+id/tv_teacher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    tools:text="by Prof. John Doe" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/divider"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- Grid/Metrics Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <!-- Downloads Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_downloads"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="1.2k" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Downloads"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:background="@color/divider" />

                    <!-- Rating Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="4.7 ★" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rating"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:background="@color/divider" />

                    <!-- Likes Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_likes_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="840" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Likes"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/divider"
                    android:layout_marginBottom="@dimen/spacing_lg" />

                <!-- Action Button Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <!-- Outline bookmark button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_bookmark"
                        style="@style/CampusConnect.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Save"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        app:icon="@drawable/ic_like_outline"
                        app:iconTint="?attr/colorPrimary" />

                    <!-- Solid Open/Download button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_open_document"
                        style="@style/CampusConnect.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="2"
                        android:text="Download PDF"
                        android:textSize="@dimen/text_subtitle"
                        android:textStyle="bold"
                        app:icon="@android:drawable/stat_sys_download_done"
                        app:iconTint="@color/white" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
