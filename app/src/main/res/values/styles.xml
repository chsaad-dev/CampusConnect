<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base style for implicit inheritance -->
    <style name="CampusConnect" />

    <!-- ========== CARD STYLES ========== -->
    <style name="CampusConnect.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/corner_medium</item>
        <item name="cardElevation">@dimen/card_elevation_flat</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="CampusConnect.Card.Elevated">
        <item name="cardElevation">@dimen/card_elevation_low</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="CampusConnect.Card.Flat">
        <item name="cardElevation">@dimen/card_elevation_flat</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@android:color/transparent</item>
    </style>

    <!-- ========== BUTTON STYLES ========== -->
    <style name="CampusConnect.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_pill</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CampusConnect.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_pill</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="strokeColor">?attr/colorOutline</item>
    </style>

    <style name="CampusConnect.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="CampusConnect.Button.Danger" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_pill</item>
        <item name="backgroundTint">@color/error</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="CampusConnect.Button.Small" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_pill</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <style name="CampusConnect.Button.Small.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_pill</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <!-- ========== TOOLBAR STYLES ========== -->
    <style name="CampusConnect.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/CampusConnect.TextAppearance.Toolbar</item>
        <item name="android:background">?attr/colorSurface</item>
    </style>

    <style name="CampusConnect.TextAppearance.Toolbar" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- ========== CHIP STYLES ========== -->
    <style name="CampusConnect.Chip.PostType" parent="Widget.Material3.Chip.Assist">
        <item name="chipMinHeight">26dp</item>
        <item name="chipCornerRadius">@dimen/corner_small</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textSize">@dimen/text_overline</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="chipMinTouchTargetSize">0dp</item>
        <item name="chipStartPadding">8dp</item>
        <item name="chipEndPadding">8dp</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>

    <!-- ========== TEXT INPUT STYLES ========== -->
    <style name="CampusConnect.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_medium</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_medium</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_medium</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_medium</item>
        <item name="boxStrokeColor">@color/text_input_stroke_color</item>
        <item name="hintTextColor">?attr/colorPrimary</item>
    </style>

    <style name="CampusConnect.TextInput.Rounded" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_pill</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_pill</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_pill</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_pill</item>
    </style>

    <!-- ========== TEXT APPEARANCE ========== -->
    <style name="CampusConnect.TextAppearance.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>

    <style name="CampusConnect.TextAppearance.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="CampusConnect.TextAppearance.Subtitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="CampusConnect.TextAppearance.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="CampusConnect.TextAppearance.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ========== TAB LAYOUT ========== -->
    <style name="CampusConnect.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">?attr/colorPrimary</item>
        <item name="tabSelectedTextColor">?attr/colorPrimary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabRippleColor">@color/ripple_color</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabIndicatorHeight">3dp</item>
    </style>

    <!-- ========== BOTTOM NAVIGATION ========== -->
    <style name="CampusConnect.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="android:background">?attr/colorSurface</item>
        <item name="itemActiveIndicatorStyle">@style/CampusConnect.BottomNav.ActiveIndicator</item>
    </style>

    <style name="CampusConnect.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_container</item>
    </style>

    <!-- ========== EMPTY STATE ========== -->
    <style name="CampusConnect.EmptyState.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CampusConnect.EmptyState.Description" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <!-- ========== LIST ITEM ========== -->
    <style name="CampusConnect.ListItem">
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="android:paddingTop">@dimen/spacing_sm</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
    </style>

</resources>
