<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Light Theme (default) - never follows system -->
    <style name="Theme.CampusConnect" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>

        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorOutline">@color/outline</item>

        <!-- Status & Navigation Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Default font family -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Component styles -->
        <item name="materialCardViewStyle">@style/CampusConnect.Card</item>
        <item name="tabStyle">@style/CampusConnect.TabLayout</item>
        <item name="bottomNavigationStyle">@style/CampusConnect.BottomNavigation</item>

        <!-- Shape appearances -->
        <item name="shapeAppearanceSmallComponent">@style/CampusConnect.ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/CampusConnect.ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/CampusConnect.ShapeLarge</item>
    </style>

    <!-- Shape Appearances -->
    <style name="CampusConnect.ShapeSmall" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">@dimen/corner_small</item>
    </style>

    <style name="CampusConnect.ShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">@dimen/corner_medium</item>
    </style>

    <style name="CampusConnect.ShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">@dimen/corner_large</item>
    </style>

    <!-- Splash Screen Theme (uses Android 12+ SplashScreen library) -->
    <style name="Theme.CampusConnect.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcherd</item>
        <item name="windowSplashScreenAnimationDuration">900</item>
        <item name="postSplashScreenTheme">@style/Theme.CampusConnect</item>
    </style>

    <!-- Corner size overlay to force images to be perfectly circular -->
    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>

</resources>