<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/auth_nav_graph">

    <!-- ======================== AUTH NAV GRAPH ======================== -->
    <navigation
        android:id="@+id/auth_nav_graph"
        app:startDestination="@id/loginFragment">

        <fragment
            android:id="@+id/loginFragment"
            android:name="com.campusconnect.feature.auth.LoginFragment"
            android:label="Login"
            tools:layout="@layout/fragment_login">

            <action
                android:id="@+id/action_loginFragment_to_registerFragment"
                app:destination="@id/registerFragment"
                app:enterAnim="@anim/slide_in_right"
                app:exitAnim="@anim/slide_out_left"
                app:popEnterAnim="@anim/slide_in_left"
                app:popExitAnim="@anim/slide_out_right" />

            <action
                android:id="@+id/action_loginFragment_to_forgotPasswordFragment"
                app:destination="@id/forgotPasswordFragment"
                app:enterAnim="@anim/slide_in_right"
                app:exitAnim="@anim/slide_out_left"
                app:popEnterAnim="@anim/slide_in_left"
                app:popExitAnim="@anim/slide_out_right" />

            <action
                android:id="@+id/action_loginFragment_to_mainNavGraph"
                app:destination="@id/main_nav_graph"
                app:popUpTo="@id/auth_nav_graph"
                app:popUpToInclusive="true" />

            <action
                android:id="@+id/action_loginFragment_to_profileCompletionFragment"
                app:destination="@id/profileCompletionFragment"
                app:popUpTo="@id/loginFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <fragment
            android:id="@+id/registerFragment"
            android:name="com.campusconnect.feature.auth.RegisterFragment"
            android:label="Register"
            tools:layout="@layout/fragment_register">

            <action
                android:id="@+id/action_registerFragment_to_emailVerificationFragment"
                app:destination="@id/emailVerificationFragment"
                app:popUpTo="@id/registerFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <fragment
            android:id="@+id/forgotPasswordFragment"
            android:name="com.campusconnect.feature.auth.ForgotPasswordFragment"
            android:label="Forgot Password"
            tools:layout="@layout/fragment_forgot_password" />

        <fragment
            android:id="@+id/emailVerificationFragment"
            android:name="com.campusconnect.feature.auth.EmailVerificationFragment"
            android:label="Verify Email"
            tools:layout="@layout/fragment_email_verification">

            <action
                android:id="@+id/action_emailVerificationFragment_to_profileCompletionFragment"
                app:destination="@id/profileCompletionFragment"
                app:popUpTo="@id/emailVerificationFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <fragment
            android:id="@+id/profileCompletionFragment"
            android:name="com.campusconnect.feature.profile.ProfileCompletionFragment"
            android:label="Complete Profile"
            tools:layout="@layout/fragment_profile_completion">

            <action
                android:id="@+id/action_profileCompletionFragment_to_mainNavGraph"
                app:destination="@id/main_nav_graph"
                app:popUpTo="@id/auth_nav_graph"
                app:popUpToInclusive="true" />
        </fragment>

    </navigation>

    <!-- ======================== MAIN NAV GRAPH ======================== -->
    <navigation
        android:id="@+id/main_nav_graph"
        app:startDestination="@id/homeFragment">

        <fragment
            android:id="@+id/homeFragment"
            android:name="com.campusconnect.feature.feed.HomeFragment"
            android:label="Home"
            tools:layout="@layout/fragment_home">
            <action
                android:id="@+id/action_homeFragment_to_createPostFragment"
                app:destination="@id/createPostFragment"
                app:enterAnim="@anim/slide_in_right"
                app:exitAnim="@anim/slide_out_left"
                app:popEnterAnim="@anim/slide_in_left"
                app:popExitAnim="@anim/slide_out_right" />
        </fragment>

        <fragment
            android:id="@+id/createPostFragment"
            android:name="com.campusconnect.feature.post.CreatePostFragment"
            android:label="Create Post"
            tools:layout="@layout/fragment_create_post" />

        <fragment
            android:id="@+id/settingsFragment"
            android:name="com.campusconnect.feature.settings.SettingsFragment"
            android:label="Settings"
            tools:layout="@layout/fragment_settings">

            <action
                android:id="@+id/action_settingsFragment_to_authNavGraph"
                app:destination="@id/auth_nav_graph"
                app:popUpTo="@id/main_nav_graph"
                app:popUpToInclusive="true" />
        </fragment>

    </navigation>

</navigation>